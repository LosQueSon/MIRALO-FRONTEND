# Environment variables for MIRALO-FRONTEND

# Public URL of the API Gateway used by the frontend (producción)
NEXT_PUBLIC_API_GATEWAY_URL=https://miralo-api-gateway-a9guhdgjenc4ahem.canadacentral-01.azurewebsites.net/

# (Opcional) Si en el futuro se requiere Google Client ID para frontend, dejar vacío o documentar su uso
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# No incluir secretos ni credenciales reales en este archivo
# Este archivo es solo ejemplo, los valores reales van en .env.local o en variables de entorno de Vercel
